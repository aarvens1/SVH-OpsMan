{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm install)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(find . -name *.ts *)",
      "Bash(grep * mcp-server/src/**)",
      "Bash(grep * collector/src/**)",
      "Read(.claude/**)",
      "Read(mcp-server/src/**)",
      "Read(mcp-server/package.json)",
      "Read(mcp-server/tsconfig.json)",
      "Read(collector/src/**)",
      "Read(collector/package.json)",
      "Read(collector/tsconfig.json)",
      "Read(staging/**)",
      "Read(references/**)",
      "Read(scripts/**)",
      "Read(systemd/**)",
      "Read(README.md)",
      "Read(CLAUDE.md)",
      "Read(.gitignore)"
    ],
    "deny": [
      "Read(mcp-server/.env)",
      "Read(collector/.env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "mcp__desktop-commander__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/desktop-commander-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-use.sh"
          }
        ]
      }
    ]
  }
}
