    "defaultProfile": "{a5e8c1d9-4f32-4a8b-9c6e-1b2d3e4f5a6b}",
    "copyOnSelect": false,
    "copyFormatting": "none",
    "tabWidthMode": "compact",

    "profiles": {
        "defaults": {
            "font": {
                "face": "Cascadia Code NF",
                "size": 12,
                "ligatures": true
            },
            "colorScheme": "Gruvbox Dark",
            "historySize": 32767,
            "opacity": 95,
            "useAcrylic": true,
            "cursorShape": "bar",
            "padding": "8",
            "scrollbarState": "visible"
        },
        "list": [
            {
                "name": "Claude Code",
                "guid": "{a5e8c1d9-4f32-4a8b-9c6e-1b2d3e4f5a6b}",
                "commandline": "wsl.exe -- bash -l -c \"cd ~/SVH-OpsMan && exec claude\"",
                "startingDirectory": "//wsl$/Ubuntu/home/astevens",
                "tabColor": "#83a598"
            },
            {
                "name": "PowerShell (OpsMan)",
                "guid": "{b7d2e3f4-5a6b-7c8d-9e0f-1a2b3c4d5e6f}",
                "commandline": "pwsh.exe -NoLogo -NoExit -Command \". $env:USERPROFILE\\SVH-OpsMan\\dotfiles\\profile.ps1 -ErrorAction SilentlyContinue\"",
                "startingDirectory": "%USERPROFILE%",
                "tabColor": "#fabd2f"
            },
            {
                "name": "WSL Bash",
                "guid": "{c8d9e0f1-a2b3-4c5d-6e7f-8a9b0c1d2e3f}",
                "commandline": "wsl.exe -- bash -l -c \"cd ~/SVH-OpsMan && exec zsh\"",
                "startingDirectory": "//wsl$/Ubuntu/home/astevens/SVH-OpsMan",
                "tabColor": "#b8bb26"
            },
            {
                "name": "Windows PowerShell",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": false
            },
            {
                "name": "Command Prompt",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "hidden": true
            }
        ]
    },

    "schemes": [
        {
            "name": "Gruvbox Dark",
            "background": "#282828",
            "foreground": "#ebdbb2",
            "black": "#282828",
            "blue": "#458588",
            "brightBlack": "#928374",
            "brightBlue": "#83a598",
            "brightCyan": "#8ec07c",
            "brightGreen": "#b8bb26",
