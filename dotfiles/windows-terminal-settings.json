    "actions": [
        { "command": { "action": "sendInput", "input": "/day-starter\r" },            "keys": "ctrl+alt+d" },
        { "command": { "action": "sendInput", "input": "/day-ender\r" },              "keys": "ctrl+alt+e" },
        { "command": { "action": "sendInput", "input": "/week-starter\r" },           "keys": "ctrl+alt+w" },
        { "command": { "action": "sendInput", "input": "/posture-check\r" },          "keys": "ctrl+alt+p" },
        { "command": { "action": "sendInput", "input": "/troubleshoot\r" },           "keys": "ctrl+alt+t" },
        { "command": { "action": "sendInput", "input": "/network-troubleshooter\r" }, "keys": "ctrl+alt+n" },
        { "command": { "action": "sendInput", "input": "/change-record\r" },          "keys": "ctrl+alt+c" },
        { "command": { "action": "sendInput", "input": "/vuln-triage\r" },            "keys": "ctrl+alt+v" },
        { "command": { "action": "sendInput", "input": "/asset-investigation\r" },    "keys": "ctrl+alt+a" },
        { "command": { "action": "sendInput", "input": "/patch-campaign\r" },         "keys": "ctrl+alt+x" },

        { "command": { "action": "newTab", "profile": "Claude Code" },                "keys": "ctrl+shift+alt+c" },
        { "command": { "action": "newTab", "profile": "PowerShell (OpsMan)" },        "keys": "ctrl+shift+alt+p" },
        { "command": { "action": "newTab", "profile": "WSL Bash" },                   "keys": "ctrl+shift+alt+b" },

        { "command": { "action": "splitPane", "split": "horizontal", "profile": "Claude Code" }, "keys": "ctrl+alt+2" },
        { "command": { "action": "splitPane", "split": "vertical" },                   "keys": "ctrl+alt+minus" },

        { "command": { "action": "moveFocus", "direction": "left" },  "keys": "ctrl+alt+h" },
        { "command": { "action": "moveFocus", "direction": "down" },  "keys": "ctrl+alt+j" },
        { "command": { "action": "moveFocus", "direction": "up" },    "keys": "ctrl+alt+k" },
        { "command": { "action": "moveFocus", "direction": "right" }, "keys": "ctrl+alt+l" },

        { "command": "renameTab",  "keys": "ctrl+alt+r" },
        { "command": "newTab",     "keys": "ctrl+shift+t" },
        { "command": "closeTab",   "keys": "ctrl+shift+w" },
        { "command": "find",       "keys": "ctrl+shift+f" },
        { "command": "copy",       "keys": "ctrl+shift+c" },
        { "command": "paste",      "keys": "ctrl+shift+v" }
    ]
