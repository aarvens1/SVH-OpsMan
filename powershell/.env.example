# SVH PowerShell credential file
# Copy to .env and fill in values — or use Bitwarden (preferred).
# Field names must match the Bitwarden "SVH OpsMan" vault item custom fields exactly.
# .env is gitignored. Never commit real credentials.

# Microsoft Graph (covers Entra, M365, Intune, Teams, Outlook, SharePoint, Planner)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# Microsoft Defender for Endpoint (separate app registration)
MDE_TENANT_ID=
MDE_CLIENT_ID=
MDE_CLIENT_SECRET=

# Azure Resource Manager
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# NinjaOne RMM
NINJA_CLIENT_ID=
NINJA_CLIENT_SECRET=
# Default org ID for server-fleet queries — SVH servers live in their own NinjaOne org
SVH_NINJA_DEFAULT_ORG=

# Wazuh SIEM (on-prem, self-signed cert — SSL verification skipped)
WAZUH_URL=https://localhost:55000
WAZUH_USERNAME=
WAZUH_PASSWORD=

# UniFi Cloud API
UNIFI_API_KEY=
# Default site ID for the most-used UniFi site — override per-call for other sites
SVH_UNIFI_DEFAULT_SITE=

# UniFi Network Controller (on-prem — SSL verification skipped)
UNIFI_CONTROLLER_URL=https://192.168.1.1
UNIFI_USERNAME=
UNIFI_PASSWORD=

# Atlassian Confluence
CONFLUENCE_DOMAIN=svh
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Vasion / PrinterLogic
PRINTERLOGIC_URL=https://svh.printercloud.com
PRINTERLOGIC_API_TOKEN=
