# Copy to .env and fill in values for local development.
# In production (WSL), export these in your shell profile instead.

# ── Microsoft Graph ───────────────────────────────────────────────────────────
# Covers: Planner, To Do, Entra ID, OneDrive, SharePoint, Teams, Outlook,
#         Exchange Admin, Intune, MS Admin
# App registration permissions (Application):
#   Tasks.ReadWrite, Group.Read.All, ChannelMessage.Send, Files.ReadWrite.All,
#   Policy.Read.All, Application.Read.All, RoleManagement.Read.Directory,
#   IdentityRiskyUser.ReadWrite.All, UserAuthenticationMethod.Read.All,
#   AuditLog.Read.All, Mail.ReadWrite, Mail.Send, Calendars.ReadWrite,
#   MailboxSettings.Read, DeviceManagementManagedDevices.Read.All,
#   DeviceManagementConfiguration.Read.All, DeviceManagementApps.Read.All,
#   ServiceHealth.Read.All, Organization.Read.All, Directory.Read.All,
#   Sites.Read.All, Reports.Read.All
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ── Microsoft Defender for Endpoint ──────────────────────────────────────────
# Requires a SEPARATE app registration with WindowsDefenderATP permissions:
#   Machine.Read.All, Alert.Read.All, Ti.Read, Vulnerability.Read.All,
#   Software.Read.All, AdvancedQuery.Read.All
MDE_TENANT_ID=
MDE_CLIENT_ID=
MDE_CLIENT_SECRET=

# ── Azure Resource Manager ────────────────────────────────────────────────────
# Service principal with Reader + Cost Management Reader at subscription scope.
# Create with: az ad sp create-for-rbac --role Reader --scopes /subscriptions/<id>
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── UniFi ─────────────────────────────────────────────────────────────────────
UNIFI_API_KEY=
UNIFI_CONTROLLER_URL=https://192.168.1.1
UNIFI_USERNAME=
UNIFI_PASSWORD=

# ── NinjaOne RMM ──────────────────────────────────────────────────────────────
NINJA_CLIENT_ID=
NINJA_CLIENT_SECRET=

# ── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_DOMAIN=your-org
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# ── Todoist ───────────────────────────────────────────────────────────────────
TODOIST_API_TOKEN=

# ── Wazuh SIEM ────────────────────────────────────────────────────────────────
WAZUH_URL=https://wazuh-manager:55000
WAZUH_USERNAME=
WAZUH_PASSWORD=

# ── PrinterLogic / Vasion ─────────────────────────────────────────────────────
PRINTERLOGIC_URL=https://your-instance.printercloud.com
PRINTERLOGIC_API_TOKEN=

# ── Threat Intel ──────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
GREYNOISE_API_KEY=
# NVD, EPSS, CISA KEV, and MITRE ATT&CK are free — no key needed
