<?xml version="1.0" encoding="utf-8"?>
<!--
  Euphoria (LE) — VPX Table Definition
  Format: VPX XML export (import via File > Import XML in VPX 10.7+)
  All primitive/texture/sound asset paths are relative to this file.
  See Euphoria.vbs for the complete game script.
-->
<root>

  <!-- ================================================================
       TABLE PROPERTIES
       ================================================================ -->
  <TableInfo>
    <TableName>Euphoria (LE)</TableName>
    <AuthorName>Claude / SVH</AuthorName>
    <TableVersion>1.0.0</TableVersion>
    <ReleaseDate>2026-06-28</ReleaseDate>
    <AuthorEmail></AuthorEmail>
    <AuthorWebSite></AuthorWebSite>
    <TableDescription>
      Virtual pinball recreation of a Stern Spike 2 style widebody machine
      themed to Euphoria (HBO). Features Ferris Wheel 3-ball lock,
      Spiral sub-playfield with mini-flippers, Bathroom Door motorized drop
      target, Glitter Drop Spinner, M-A-D-D-Y drop target bank, and
      All For Us wizard mode with BPM-synced flashers.
    </TableDescription>
    <TableRules></TableRules>
    <TableSaveDate>2026-06-28</TableSaveDate>
    <TableSaveRev>1</TableSaveRev>
  </TableInfo>

  <!-- ================================================================
       PHYSICS / ENVIRONMENT
       ================================================================ -->
  <TablePhysics>
    <!-- 6.5-degree pitch — standard fast-flow modern table -->
    <Gravity>0.97</Gravity>
    <Friction>0.075</Friction>
    <Elasticity>0.25</Elasticity>
    <ElasticityFalloff>0.0</ElasticityFalloff>
    <Scatter>0.0</Scatter>
    <DefaultScatter>0.0</DefaultScatter>
    <NudgeTime>5</NudgeTime>
    <PlungerNormalize>100</PlungerNormalize>
    <PlungerFilter>false</PlungerFilter>
    <PhysicsMaxLoops>0</PhysicsMaxLoops>
    <RenderDecals>true</RenderDecals>
    <RenderEMReels>true</RenderEMReels>
    <OverridePhysics>0</OverridePhysics>
    <OverridePhysicsFlipper>false</OverridePhysicsFlipper>
  </TablePhysics>

  <TableDimensions>
    <!-- Stern widebody: 20.25" x 42.0" scaled to VPX units -->
    <Width>2025</Width>
    <Height>4200</Height>
    <GlassHeight>210</GlassHeight>
    <BallRadius>27</BallRadius>
    <BallMass>1.0</BallMass>
  </TableDimensions>

