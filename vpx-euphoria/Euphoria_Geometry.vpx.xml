<?xml version="1.0" encoding="utf-8"?>
<!--
  Euphoria (LE) — Geometry & Physics Objects
  Merge with Euphoria.vpx.xml (or import in addition to it).

  Covers:
    - All playfield walls (side walls, orbit guides, ramp entrances/exits,
      slingshot backs, inlane/outlane guides, center drain guide)
    - Rubber posts (scatter posts, corner posts, flipper end posts)
    - Slingshot kicker walls
    - Ball trough (5-ball, Stern style)
    - Shooter / plunger lane
    - One-way gates (left/right orbit)
    - Spinner object (Glitter Drop)
    - Sub-playfield surface (The Spiral)
    - Diverter (Stage Ramp)
    - Rubber materials

  All X/Y in VPX units. Table: 2025 wide × 4200 tall.
  Y=0 is the TOP (backbox end); Y=4200 is the BOTTOM (drain end).
-->
<root>

  <!-- ================================================================
       MATERIALS
       ================================================================ -->
  <Materials>
    <Material name="Playfield_Wood">
      <WrapLighting>0.1</WrapLighting>
      <Roughness>0.6</Roughness>
      <GlossyImageLerp>0.5</GlossyImageLerp>
      <Thickness>0.05</Thickness>
      <Edge>1.0</Edge>
      <EdgeAlpha>1.0</EdgeAlpha>
      <Opacity>1.0</Opacity>
      <IsMetal>false</IsMetal>
    </Material>
    <Material name="Rubber_Black">
      <WrapLighting>0.4</WrapLighting>
      <Roughness>0.9</Roughness>
      <Elasticity>0.48</Elasticity>
      <ElasticityFalloff>0.0</ElasticityFalloff>
      <Friction>0.6</Friction>
      <ScatterAngle>0.0</ScatterAngle>
      <IsMetal>false</IsMetal>
    </Material>
    <Material name="Rubber_White">
      <WrapLighting>0.4</WrapLighting>
      <Roughness>0.85</Roughness>
      <Elasticity>0.52</Elasticity>
      <Friction>0.55</Friction>
      <IsMetal>false</IsMetal>
    </Material>
    <Material name="Metal_Chrome">
      <WrapLighting>0.0</WrapLighting>
      <Roughness>0.05</Roughness>
      <Elasticity>0.25</Elasticity>
      <Friction>0.07</Friction>
      <IsMetal>true</IsMetal>
    </Material>
    <Material name="Flipper_Rubber">
      <WrapLighting>0.3</WrapLighting>
      <Roughness>0.8</Roughness>
      <Elasticity>0.88</Elasticity>
      <ElasticityFalloff>0.0</ElasticityFalloff>
      <Friction>0.6</Friction>
      <ScatterAngle>0.0</ScatterAngle>
      <IsMetal>false</IsMetal>
    </Material>
    <Material name="Kicker_Metal">
      <WrapLighting>0.0</WrapLighting>
      <Roughness>0.1</Roughness>
      <Elasticity>0.3</Elasticity>
      <Friction>0.1</Friction>
      <IsMetal>true</IsMetal>
    </Material>
    <Material name="Ramp_Plastic">
      <WrapLighting>0.2</WrapLighting>
      <Roughness>0.5</Roughness>
      <Elasticity>0.28</Elasticity>
      <Friction>0.17</Friction>
      <IsMetal>false</IsMetal>
    </Material>
  </Materials>

  <!-- ================================================================
       SURFACES (sub-playfield heights)
       ================================================================ -->
  <Surfaces>
    <!-- Main playfield at Z=0 -->
    <Surface name="Playfield">
      <Z>0</Z>
      <Image>playfield_diffuse</Image>
      <SideImage></SideImage>
      <Material>Playfield_Wood</Material>
    </Surface>
    <!-- The Spiral sub-playfield raised 30 VPX units -->
    <Surface name="SubPlayfield_Spiral">
      <Z>30</Z>
      <Image>playfield_diffuse</Image>
      <Material>Playfield_Wood</Material>
    </Surface>
    <!-- Stage Ramp surface -->
    <Surface name="Ramp_Stage">
      <Z>0</Z>
      <HeightBottom>0</HeightBottom>
      <HeightTop>120</HeightTop>
      <Image></Image>
      <Material>Ramp_Plastic</Material>
      <IsVisible>true</IsVisible>
      <IsCollidable>true</IsCollidable>
    </Surface>
    <!-- Ferris Wheel Ramp surface -->
    <Surface name="Ramp_Ferris">
      <Z>0</Z>
      <HeightBottom>0</HeightBottom>
      <HeightTop>100</HeightTop>
      <Material>Ramp_Plastic</Material>
    </Surface>
  </Surfaces>

